# Supabase - Obtén estos valores en: https://supabase.com/dashboard/project/<tu-project-id>/settings/api
VITE_SUPABASE_URL=https://<tu-project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<tu-anon-public-key>

# Solo necesario para Server Functions (bypasa RLS). NO exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=<tu-service-role-key>
